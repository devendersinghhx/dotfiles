        },
        {
            "type": "wm",
            "key": "  п’Ҳ WM"
        },
        {
            "type": "shell",
            "key": "  п’ү Shell"
        },
	{
            "type": "Packages",
            "key": "  у°Ҹ” Packages"
        },
	{
            "type": "custom", // SoftwareStart
            "format": "в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ \u001b[1mNetwork\u001b[0m в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө"
